// ============================================================================
// SEED Project Tracker — Prisma schema
//
// Models the full data model from the project outline (§4) plus the tables the
// Auth.js Prisma adapter requires (Account / Session / VerificationToken).
//
// Roles are DATA, not hardcoded: a Role carries a set of Permission flags and
// the PM can create custom roles. The three "built-in" roles are just
// pre-seeded rows (see prisma/seed.ts).
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Direct (non-pooled) connection for migrations against Supabase.
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserStatus {
  PENDING // new sign-in, awaiting PM approval — cannot use the app yet
  ACTIVE
  SUSPENDED
}

enum ProjectStatus {
  ON_TRACK
  AT_RISK
  BEHIND
}

enum ActionItemStatus {
  OPEN
  DONE
}

/// Granular permission flags. A Role grants a set of these. Custom roles are
/// just different combinations the PM assembles in the role builder.
enum Permission {
  VIEW_ALL_PROJECTS // read every project
  VIEW_ASSIGNED_PROJECTS // read only projects the user is assigned to
  SUBMIT_STATUS_UPDATES // submit pre-meeting status updates
  EDIT_OWN_PROJECT // edit projects the user leads
  POST_MEETING_TRACKING // record post-meeting tracking
  MANAGE_PROJECTS // create / edit / delete any project
  MANAGE_MILESTONES // define and edit milestones
  ASSIGN_ACTION_ITEMS // create / assign action items
  CLOSE_ACTION_ITEMS // mark action items done
  VIEW_MONTHLY_REVIEW // see the monthly review dashboard
  CONFIGURE_NOTIFICATIONS // manage notification rules & red-flag thresholds
  MANAGE_USERS // approve / assign / suspend users
  MANAGE_ROLES // create / edit custom roles & permissions
}

/// What event a NotificationRule reacts to.
enum TriggerType {
  MISSING_SUBMISSION // lead hasn't submitted before the meeting deadline
  PROJECT_BEHIND // a project trips the "Behind" auto-flag
  ACTION_ITEM_DUE // an action item is nearing / past its deadline
  GOAL_MISSED // a weekly goal was recorded as not met
}

enum Channel {
  EMAIL
  IN_APP
  BOTH
}

/// Who receives a notification when a rule fires.
enum RecipientGroup {
  PM
  PROJECT_LEADS
  ACTION_OWNER
  ALL_ACTIVE
}

enum NotificationType {
  REMINDER
  PROJECT_BEHIND
  ACTION_ITEM
  GOAL_MISSED
  USER_APPROVAL
  GENERAL
}

// ---------------------------------------------------------------------------
// RBAC: Role + permissions
// ---------------------------------------------------------------------------

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  isBuiltIn   Boolean      @default(false) // built-ins can't be deleted
  permissions Permission[] // the set of capabilities this role grants
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// ---------------------------------------------------------------------------
// Users + Auth.js adapter models
// ---------------------------------------------------------------------------

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  image         String?
  status        UserStatus @default(PENDING)
  roleId        String?
  role          Role?      @relation(fields: [roleId], references: [id])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Auth.js relations
  accounts Account[]
  sessions Session[]

  // Domain relations
  assignments     ProjectAssignment[]
  statusUpdates   StatusUpdate[]
  meetingRecords  MeetingRecord[]     @relation("RecordedBy")
  ownedActionItems ActionItem[]       @relation("ActionItemOwner")
  notifications   Notification[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Projects + the semester plan
// ---------------------------------------------------------------------------

model Project {
  id                   String        @id @default(cuid())
  name                 String
  description          String?
  semester             String // e.g. "Fall 2026"
  status               ProjectStatus @default(ON_TRACK)
  statusOverride       Boolean       @default(false) // true = PM manually set status, suppress auto-detection
  correctiveActionPlan String?       @db.Text // required to be filled when flagged Behind (Red Flag Rule)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  assignments    ProjectAssignment[]
  milestones     Milestone[]
  statusUpdates  StatusUpdate[]
  meetingRecords MeetingRecord[]
  actionItems    ActionItem[]
}

/// Join table: which users lead which projects.
model ProjectAssignment {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
}

model Milestone {
  id            String    @id @default(cuid())
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title         String
  targetDate    DateTime
  completed     Boolean   @default(false)
  completedDate DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([projectId])
}

// ---------------------------------------------------------------------------
// The weekly loop: pre-meeting status updates + post-meeting tracking
// ---------------------------------------------------------------------------

model StatusUpdate {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  submittedById  String
  submittedBy    User     @relation(fields: [submittedById], references: [id])
  meetingDate    DateTime // the meeting/week this update is for
  plannedWork    String   @db.Text
  actualProgress String   @db.Text
  blockers       String   @db.Text
  nextWeekGoals  String   @db.Text
  needsHelp      Boolean  @default(false)
  helpNeeded     String?  @db.Text
  submittedAt    DateTime @default(now())
  isLate         Boolean  @default(false) // submitted after the 24h-before-meeting deadline
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([projectId, meetingDate])
}

model MeetingRecord {
  id           String        @id @default(cuid())
  projectId    String
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  meetingDate  DateTime
  status       ProjectStatus // status the PM assigned at this meeting
  goalMet      Boolean? // weekly goal met? (null = not recorded)
  keyBlockers  String?       @db.Text
  notes        String?       @db.Text
  recordedById String
  recordedBy   User          @relation("RecordedBy", fields: [recordedById], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  actionItems ActionItem[] @relation("MeetingActionItems")

  @@index([projectId, meetingDate])
}

// ---------------------------------------------------------------------------
// Accountability: action items
// ---------------------------------------------------------------------------

model ActionItem {
  id          String           @id @default(cuid())
  projectId   String
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  description String           @db.Text
  ownerId     String?
  owner       User?            @relation("ActionItemOwner", fields: [ownerId], references: [id])
  deadline    DateTime?
  status      ActionItemStatus @default(OPEN)
  carriedOver Boolean          @default(false) // rolled over from a previous week while still open

  meetingId String?
  meeting   MeetingRecord? @relation("MeetingActionItems", fields: [meetingId], references: [id])

  createdAt   DateTime  @default(now())
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@index([projectId, status])
  @@index([ownerId, status])
}

// ---------------------------------------------------------------------------
// Notifications & configurable triggers
// ---------------------------------------------------------------------------

/// PM-configurable rule: what event fires, at what threshold, on which channel,
/// to whom. The red-flag thresholds (§5.3) live on the Settings singleton; the
/// PROJECT_BEHIND rule just controls whether/where to notify when it trips.
model NotificationRule {
  id          String         @id @default(cuid())
  name        String
  triggerType TriggerType
  channel     Channel        @default(BOTH)
  recipients  RecipientGroup
  enabled     Boolean        @default(true)
  // Generic knobs interpreted per trigger type, e.g.:
  //  - MISSING_SUBMISSION / ACTION_ITEM_DUE: `hoursBefore` (Int)
  thresholdHours Int? // hours-before-deadline for time-based triggers
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

/// In-app notification (the "bell"). Email is sent separately via Resend.
model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType @default(GENERAL)
  title     String
  body      String?          @db.Text
  link      String? // optional in-app link to the relevant page
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read])
}

/// Single-row table holding global, PM-configurable settings — currently the
/// red-flag auto-detection thresholds (§5.3). Always read/written with id="singleton".
model Settings {
  id                  String  @id @default("singleton")
  // Auto-flag a project Behind when EITHER (or BOTH, per requireBoth) condition holds.
  weeksBehindMilestone Int    @default(1) // >= this many weeks past a milestone target
  missedGoalsInARow   Int     @default(2) // this many consecutive missed weekly goals
  requireBoth         Boolean @default(false) // true = both conditions required; false = either
  // The submission deadline window: a status update is "late" if submitted
  // fewer than this many hours before the meeting.
  submissionDeadlineHours Int @default(24)
  updatedAt           DateTime @updatedAt
}
